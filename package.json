{
  "name": "founder-control-plane",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web \"bun run --cwd apps/api dev\" \"bun run --cwd apps/web dev\"",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:worker": "bun run --cwd apps/worker dev",
    "services:up": "docker compose up -d postgres redis",
    "services:down": "docker compose down",
    "playwright:install": "bunx playwright install --with-deps chromium",
    "test": "bun test apps/api/tests apps/web/src",
    "test:unit": "bun test apps/api/tests apps/web/src",
    "test:e2e:onboarding": "bunx playwright test apps/web/e2e/onboarding.spec.ts",
    "test:e2e:connectors": "bunx playwright test apps/web/e2e/connectors.spec.ts",
    "test:list:e2e": "bunx playwright test --list",
    "test:e2e:s08": "bunx playwright test apps/web/e2e/founder-proof.spec.ts",
    "typecheck": "bun tsc -p apps/api/tsconfig.json --noEmit && bun tsc -p apps/web/tsconfig.json --noEmit && bun tsc -p packages/shared/tsconfig.json --noEmit && bun tsc -p apps/worker/tsconfig.json --noEmit",
    "lint": "bun run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.7.2",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.4",
    "typescript": "^5.9.3",
    "ultracite": "7.4.2",
    "vitest": "^3.2.4"
  }
}
