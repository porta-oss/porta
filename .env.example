# Porta — Runtime environment
# Copy to .env and fill in required values before running.

# Shared runtime
NODE_ENV=development
PORTA_EDITION=community
API_HOST=0.0.0.0
API_PORT=3000
WEB_HOST=0.0.0.0
WEB_PORT=5173
API_URL=http://localhost:3000
WEB_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-local-secret-at-least-32-characters-long
CONNECTOR_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/porta
REDIS_URL=redis://127.0.0.1:6379
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MAGIC_LINK_SENDER_EMAIL=dev@porta.local
AUTH_CONTEXT_TIMEOUT_MS=2000
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_POOL_MAX=10

# Anthropic — optional, enables AI-powered insight generation
# ANTHROPIC_API_KEY=sk-ant-...

# Linear — optional, enables task-to-Linear issue sync from the worker
# Get an API key at https://linear.app/settings/api
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=your-team-uuid

# Founder-proof mode — enables deterministic connector validation for local/CI proof runs.
# When true, PostHog and Stripe connectors accept demo credentials without calling live APIs.
# Must be set explicitly; absent or empty keeps the default (disabled).
# Valid values: true, false, 1, 0, or absent.
# FOUNDER_PROOF_MODE=true

# Docker Compose defaults
# These are used by docker-compose.yml for service configuration.
# The compose stack uses internal Docker DNS (postgres, redis, api) — not 127.0.0.1.
POSTGRES_DB=porta
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379

# Worker configuration
WORKER_CONCURRENCY=3
JOB_TIMEOUT_MS=30000
